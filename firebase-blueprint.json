{
  "entities": {
    "recommendations": {
      "title": "TravelerRecommendation",
      "description": "Busan accessible travel and gourmet recommendation tip.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "author": { "type": "string" },
        "topic": { "type": "string" },
        "category": { "type": "string", "enum": ["FOOD", "CAFE", "ATTRACTION", "TRANSIT", "OTHER"] },
        "stationOrExit": { "type": "string" },
        "content": { "type": "string" },
        "upvotes": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "author", "topic", "content"]
    }
  },
  "firestore": {
    "/recommendations/{id}": {
      "schema": "recommendations",
      "description": "Collection of traveler recommendations"
    }
  }
}
