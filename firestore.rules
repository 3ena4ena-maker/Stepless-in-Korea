rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprint for recommendations entity
    function isValidRecommendation(data) {
      return data.keys().hasAll(['id', 'author', 'topic', 'content'])
        && data.id is string
        && data.id.size() <= 128
        && data.author is string
        && data.author.size() <= 200
        && data.topic is string
        && data.topic.size() <= 200
        && data.content is string
        && data.content.size() <= 5000
        && (!data.keys().contains('category') || (data.category is string && (data.category == 'FOOD' || data.category == 'CAFE' || data.category == 'ATTRACTION' || data.category == 'TRANSIT' || data.category == 'OTHER')))
        && (!data.keys().contains('stationOrExit') || (data.stationOrExit is string && data.stationOrExit.size() <= 200))
        && (!data.keys().contains('upvotes') || (data.upvotes is int && data.upvotes >= 0))
        && (!data.keys().contains('createdAt') || (data.createdAt is string && data.createdAt.size() <= 100));
    }

    match /recommendations/{id} {
      // Allow read operations (get and list)
      allow get, list: if true;

      // Allow creation of recommendations with schema validation
      allow create: if isValidId(id) && isValidRecommendation(incoming());

      // Allow updates to recommendations: strictly limited to the 'upvotes' field
      allow update: if isValidId(id) && isValidRecommendation(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['upvotes'])
      );

      // Allow deletion
      allow delete: if isValidId(id);
    }
  }
}
